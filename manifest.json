{
  "manifest_version": 3,
  "name": "Chzzk Syncer - 치지직 싱크 컨트롤러",
  "version": "0.2.4",
  "description": "치지직 라이브 스트리밍 딜레이를 미세 조절하는 확장 프로그램입니다.",
  "permissions": ["storage"],
  "host_permissions": ["https://chzzk.naver.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Chzzk Syncer - 치지직 싱크 컨트롤러",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://chzzk.naver.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chzzk.naver.com/*"],
      "js": ["player-button.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
